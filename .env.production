# PREVIEW DEPLOY ONLY — bypasses NextAuth so the deploy is browsable
# without OAuth/MongoDB. Remove this file before Phase 2.
PREVIEW_MODE=1

# Build-time placeholders so NextAuth doesn't crash at module load.
# These are NEVER used at runtime in preview mode (auth is bypassed).
NEXTAUTH_SECRET=preview-placeholder-secret-not-used
NEXTAUTH_URL=https://command-center.vercel.app
GOOGLE_CLIENT_ID=preview-placeholder
GOOGLE_CLIENT_SECRET=preview-placeholder
ALLOWED_EMAIL=steve@ctrlrobotics.com
