# ─────────────────────────────────────────────────────────────────────────────
# Command Center — environment variables
# Copy this file to .env.local and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# NextAuth ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                # generate: `openssl rand -base64 32`

# Google OAuth (also used for Drive API v3) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Single-email gate — only this Google account can sign in
ALLOWED_EMAIL=steve@ctrlrobotics.com

# MongoDB ─────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/command-center

# Lightfield (Phase 2) ────────────────────────────────────────────────────────
LIGHTFIELD_API_KEY=
LIGHTFIELD_BASE_URL=https://api.lightfield.example.com

# Anthropic (Phase 4) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MONTHLY_BUDGET_USD=50

# Cloudinary (Phase 3 — image uploads) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Vercel cron — gate /api/cron/* with this shared secret ─────────────────────
CRON_SECRET=
